{
  "cleanUrls": true,
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/frontend/static/$1" },
    { "src": "/", "dest": "/frontend/login.html" },
    { "src": "/login", "dest": "/frontend/login.html" },
    { "src": "/signup", "dest": "/frontend/signup.html" },
    { "src": "/dashboard", "dest": "/frontend/dashboard.html" },
    { "src": "/courses", "dest": "/frontend/courses.html" },
    { "src": "/batches", "dest": "/frontend/batches.html" },
    { "src": "/faculties", "dest": "/frontend/faculty.html" },
    { "src": "/classrooms", "dest": "/frontend/rooms.html" },
    { "src": "/slots", "dest": "/frontend/slots.html" },
    { "src": "/categories", "dest": "/frontend/categories.html" },
    { "src": "/mappings", "dest": "/frontend/mappings.html" },
    { "src": "/timetable", "dest": "/frontend/timetable.html" },
    { "src": "/users", "dest": "/frontend/users.html" }
  ]
}
