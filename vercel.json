{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/static/:path*", "destination": "/frontend/static/:path*" },
    { "source": "/", "destination": "/frontend/templates/login.html" },
    { "source": "/login", "destination": "/frontend/templates/login.html" },
    { "source": "/signup", "destination": "/frontend/templates/signup.html" },
    { "source": "/dashboard", "destination": "/frontend/templates/dashboard.html" },
    { "source": "/courses", "destination": "/frontend/templates/courses.html" },
    { "source": "/batches", "destination": "/frontend/templates/batches.html" },
    { "source": "/faculties", "destination": "/frontend/templates/faculties.html" },
    { "source": "/classrooms", "destination": "/frontend/templates/classrooms.html" },
    { "source": "/slots", "destination": "/frontend/templates/slots.html" },
    { "source": "/categories", "destination": "/frontend/templates/categories.html" },
    { "source": "/mappings", "destination": "/frontend/templates/mappings.html" },
    { "source": "/timetable", "destination": "/frontend/templates/timetable.html" },
    { "source": "/users", "destination": "/frontend/templates/users.html" }
  ]
}
